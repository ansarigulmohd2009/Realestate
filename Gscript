/**
 * =============================================================================
 * APEX ESTATES — GOOGLE APPS SCRIPT BACKEND
 * =============================================================================
 * A Google Sheet acts as the database. This script exposes it as a small
 * JSON API that the apex-estates.html frontend can call.
 *
 * SETUP
 * -----
 * 1. Go to https://sheet.new to create a fresh Google Sheet.
 *    Rename it to something like "Apex Estates DB".
 * 2. Extensions > Apps Script. Delete any starter code in Code.gs and
 *    paste this entire file in its place.
 * 3. In the function dropdown (top toolbar, next to Debug), select
 *    "setupDatabase" and click Run. The first run will ask you to
 *    authorize the script — approve it (it only touches this one sheet).
 *    This creates the "Listings" and "Inquiries" tabs and seeds the
 *    Listings tab with the 8 demo properties from the frontend's
 *    MOCK_LISTINGS array, so you have real rows to look at immediately.
 * 4. Deploy > New deployment > gear icon > select type "Web app".
 *      - Execute as: Me
 *      - Who has access: Anyone
 *    Click Deploy and authorize again if asked. This version also touches
 *    Google Drive (to store uploaded listing photos), so the authorization
 *    prompt will now ask for a Drive permission too — approve it. It only
 *    creates/uses one folder called "Apex Estates Listing Images", it
 *    doesn't touch the rest of your Drive.
 * 5. Copy the "Web app URL" — it ends in /exec. That's your API_BASE_URL.
 *
 * IMPORTANT — updating the script later:
 * Editing this code does NOT update the live /exec URL by itself. After
 * changing code, go to Deploy > Manage deployments > edit (pencil) >
 * "New version" > Deploy, so the /exec URL picks up your changes. If you're
 * adding image uploads to a deployment that predates them, this redeploy
 * step is what triggers the new Drive authorization prompt — approve it.
 *
 * FRONTEND CHANGES NEEDED
 * ------------------------
 * Apps Script serves everything from one URL (no /listings or /inquiries
 * sub-paths like a normal REST API), so two small edits are needed in
 * apex-estates.html — see the note at the bottom of this file.
 * =============================================================================
 */

// CHANGE THESE before deploying — they gate the "Add Listing" admin form.
// These values live only in the server-side script, never in page source,
// so it's safe to keep them here as plain constants.
const ADMIN_USERNAME = "admin";
const ADMIN_PASSWORD = "Admin@123";

const SHEET_LISTINGS = "Listings";
const SHEET_INQUIRIES = "Inquiries";

const LISTING_HEADERS = [
  "id", "code", "title", "type", "category", "status", "price", "location",
  "sqft", "beds", "baths", "config", "year", "image", "gallery",
  "description", "amenities"
];

const INQUIRY_HEADERS = [
  "timestamp", "name", "phone", "email", "message", "propertyId", "propertyTitle"
];

/* -----------------------------------------------------------------------
   ONE-TIME SETUP — run this manually from the Apps Script editor
   ----------------------------------------------------------------------- */
function setupDatabase() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  let listings = ss.getSheetByName(SHEET_LISTINGS);
  if (!listings) listings = ss.insertSheet(SHEET_LISTINGS);
  listings.clear();
  listings.appendRow(LISTING_HEADERS);
  listings.setFrozenRows(1);
  seedListings(listings);

  let inquiries = ss.getSheetByName(SHEET_INQUIRIES);
  if (!inquiries) inquiries = ss.insertSheet(SHEET_INQUIRIES);
  inquiries.clear();
  inquiries.appendRow(INQUIRY_HEADERS);
  inquiries.setFrozenRows(1);

  const defaultSheet = ss.getSheetByName("Sheet1");
  if (defaultSheet && ss.getSheets().length > 2) ss.deleteSheet(defaultSheet);

  SpreadsheetApp.flush();
  Logger.log("Database ready: " + ss.getUrl());
}

