/* -----------------------------------------------------------------------
   WEB APP ENTRY POINTS
   ----------------------------------------------------------------------- */
function doGet(e) {
  const action = (e && e.parameter && e.parameter.action) || "listings";
  try {
    if (action === "listings") return jsonResponse(getListings());
    return jsonResponse({ error: "Unknown action: " + action });
  } catch (err) {
    return jsonResponse({ error: err.message });
  }
}

function doPost(e) {
  const action = (e && e.parameter && e.parameter.action) || "inquiry";
  try {
    const data = JSON.parse(e.postData.contents);

    if (action === "inquiry") {
      saveInquiry(data);
      return jsonResponse({ ok: true });
    }

    if (action === "login") {
      if (data.username !== ADMIN_USERNAME || data.password !== ADMIN_PASSWORD) {
        return jsonResponse({ error: "Unauthorized" });
      }
      return jsonResponse({ ok: true });
    }

    if (action === "addListing") {
      if (data.username !== ADMIN_USERNAME || data.password !== ADMIN_PASSWORD) {
        return jsonResponse({ error: "Unauthorized" });
      }
      const id = addListing(data.listing);
      return jsonResponse({ ok: true, id: id });
    }

    if (action === "updateListing") {
      if (data.username !== ADMIN_USERNAME || data.password !== ADMIN_PASSWORD) {
        return jsonResponse({ error: "Unauthorized" });
      }
      updateListing(data.id, data.listing);
      return jsonResponse({ ok: true });
    }

    if (action === "uploadImage") {
      if (data.username !== ADMIN_USERNAME || data.password !== ADMIN_PASSWORD) {
        return jsonResponse({ error: "Unauthorized" });
      }
      if (!data.imageData) {
        return jsonResponse({ error: "No image data received" });
      }
      const url = uploadImage(data.imageData, data.mimeType, data.filename);
      return jsonResponse({ ok: true, url: url });
    }

    return jsonResponse({ error: "Unknown action: " + action });
  } catch (err) {
    return jsonResponse({ error: err.message });
  }
}

/* -----------------------------------------------------------------------
   DATA ACCESS
   ----------------------------------------------------------------------- */
function getListings() {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(SHEET_LISTINGS);
  const rows = sheet.getDataRange().getValues();
  const headers = rows.shift();

  return rows
    .filter((row) => row[0] !== "") // skip blank trailing rows
    .map((row) => {
      const obj = {};
      headers.forEach((header, i) => {
        let val = row[i];
        if (header === "gallery" || header === "amenities") {
          try { val = val ? JSON.parse(val) : []; } catch (parseErr) { val = []; }
        } else if (val === "") {
          val = header === "config" ? undefined : null;
        }
        if (val !== undefined) obj[header] = val;
      });
      return obj;
    });
}

function addListing(listing) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(SHEET_LISTINGS);
  const id = "l" + new Date().getTime();

  const row = LISTING_HEADERS.map((header) => {
    if (header === "id") return id;
    let val = listing[header];
    if (header === "gallery" || header === "amenities") {
      return JSON.stringify(Array.isArray(val) ? val : []);
    }
    return val === null || val === undefined ? "" : val;
  });

  sheet.appendRow(row);
  return id;
}

function updateListing(id, listing) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(SHEET_LISTINGS);
  const rows = sheet.getDataRange().getValues();

  for (let r = 1; r < rows.length; r++) { // r=0 is row 1 (header), skip it
    if (String(rows[r][0]) === String(id)) {
      const rowValues = LISTING_HEADERS.map((header) => {
        if (header === "id") return id; // id itself never changes
        let val = listing[header];
        if (header === "gallery" || header === "amenities") {
          return JSON.stringify(Array.isArray(val) ? val : []);
        }
        return val === null || val === undefined ? "" : val;
      });
      sheet.getRange(r + 1, 1, 1, rowValues.length).setValues([rowValues]);
      return;
    }
  }
  throw new Error("Listing not found: " + id);
}

function saveInquiry(payload) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(SHEET_INQUIRIES);
  sheet.appendRow([
    new Date(),
    payload.name || "",
    payload.phone || "",
    payload.email || "",
    payload.message || "",
    payload.propertyId || "",
    payload.propertyTitle || "",
  ]);
}

/* -----------------------------------------------------------------------
   IMAGE UPLOADS — stores photos in a Drive folder next to this Sheet,
   makes them public-viewable, and returns a directly embeddable URL.
   ----------------------------------------------------------------------- */
const IMAGE_FOLDER_NAME = "Apex Estates Listing Images";

function getImageFolder() {
  const folders = DriveApp.getFoldersByName(IMAGE_FOLDER_NAME);
  if (folders.hasNext()) return folders.next();
  return DriveApp.createFolder(IMAGE_FOLDER_NAME);
}

function uploadImage(imageDataBase64, mimeType, filename) {
  const folder = getImageFolder();
  const bytes = Utilities.base64Decode(imageDataBase64);
  const blob = Utilities.newBlob(bytes, mimeType || "image/jpeg", filename || ("listing-" + new Date().getTime() + ".jpg"));
  const file = folder.createFile(blob);
  file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
  // This lh3.googleusercontent.com form is the one that reliably works as a
  // direct <img src>, unlike the drive.google.com/uc?... link.
  return "https://lh3.googleusercontent.com/d/" + file.getId();
}

/* -----------------------------------------------------------------------
   HELPERS
   ----------------------------------------------------------------------- */
function jsonResponse(obj) {
  return ContentService.createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}

/**
 * -----------------------------------------------------------------------
 * FRONTEND CHANGES NEEDED IN apex-estates.html
 * -----------------------------------------------------------------------
 * Apps Script only gives you one URL (ending in /exec) — it can't do
 * /listings and /inquiries as separate paths like a real REST API. So:
 *
 * 1. Set:
 *      const USE_MOCK_DATA = false;
 *      const API_BASE_URL = "https://script.google.com/macros/s/XXXXX/exec";
 *
 * 2. Replace fetchListings() and submitInquiry() with:
 *
 *   async function fetchListings() {
 *     const res = await fetch(`${API_BASE_URL}?action=listings`);
 *     if (!res.ok) throw new Error("Failed to load listings");
 *     return res.json();
 *   }
 *
 *   async function submitInquiry(payload) {
 *     // Content-Type must be text/plain here — a JSON content-type
 *     // triggers a CORS preflight (OPTIONS) request that Apps Script
 *     // web apps don't handle, and the request will fail silently.
 *     const res = await fetch(`${API_BASE_URL}?action=inquiry`, {
 *       method: "POST",
 *       headers: { "Content-Type": "text/plain;charset=utf-8" },
 *       body: JSON.stringify(payload),
 *     });
 *     if (!res.ok) throw new Error("Failed to submit inquiry");
 *     return res.json();
 *   }
 *
 * 3. The site's Admin tab (added separately) posts to
 *    `${API_BASE_URL}?action=login` to verify the username + password,
 *    `${API_BASE_URL}?action=addListing` with `{ username, password, listing }`,
 *    and `${API_BASE_URL}?action=updateListing` with
 *    `{ username, password, id, listing }` to edit an existing row. All
 *    three are handled by doPost() below. Change ADMIN_USERNAME and
 *    ADMIN_PASSWORD near the top of this file before deploying.
 * 4. The "Main Image" / "Gallery" file pickers on the Admin tab post to
 *    `${API_BASE_URL}?action=uploadImage` with
 *    `{ username, password, imageData, mimeType, filename }`, where
 *    imageData is a base64 string (no "data:image/...;base64," prefix —
 *    the frontend strips that before sending). It's handled by uploadImage()
 *    below, which stores the photo in the "Apex Estates Listing Images"
 *    Drive folder and returns `{ ok: true, url }` — that url is what gets
 *    written into the listing's image/gallery fields.
 * -----------------------------------------------------------------------
 */
